{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-auto-model-config",
  "version": "0.1.0",
  "description": "OpenCode plugin: auto-fill model metadata from models.dev for custom providers",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bunx vitest run",
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "opencode",
    "plugin",
    "models.dev",
    "model-config",
    "metadata"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
